<div class="sticky top-0 z-50 bg-white/96 backdrop-blur-md border-b border-gray-200 px-4 py-2.5 flex items-center justify-between">
  <div class="text-base font-semibold">My Farms</div>
  <div>
    <%= link_to alerts_path, class: "relative w-9 h-9 rounded-md border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50" do %>
      <%= icon :bell, class: "w-4 h-4" %>
      <% if Alert.active.exists? %>
        <span class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-red-500 border-2 border-white"></span>
      <% end %>
    <% end %>
  </div>
</div>

<% farms_needing_attention = @farms.select { |f| f.critical? || f.warning? } %>
<div class="flex items-center gap-2.5 px-4 py-2.5 bg-white border-b border-gray-200">
  <% if farms_needing_attention.any? %>
    <div class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_0_0_rgba(199,84,80,0.4)] animate-pulse"></div>
    <span class="text-sm font-medium text-red-500"><%= pluralize(farms_needing_attention.count, 'farm') %> needs attention</span>
  <% else %>
    <div class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_0_0_rgba(53,122,74,0.4)] animate-pulse"></div>
    <span class="text-sm font-medium text-green-600">All systems normal</span>
  <% end %>
  <span class="ml-auto text-[11px] text-gray-400">Updated just now</span>
</div>

<div class="px-4 pt-3 pb-24 space-y-2.5">
  <% @farms.each do |farm| %>
    <%= link_to farm_path(farm), class: "block bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md active:scale-[0.995] transition-all no-underline text-gray-900" do %>
      <div class="px-4 py-3.5 border-b border-gray-200 flex items-center justify-between <%= 'bg-red-50 border-red-200' if farm.critical? %> <%= 'bg-yellow-50 border-yellow-200' if farm.warning? %> <%= 'bg-green-50 border-green-200' if farm.normal? %>">
        <span class="text-sm font-semibold"><%= farm.name %></span>
        <span class="text-[11px] font-semibold uppercase tracking-wide px-2.5 py-0.5 rounded-full border <%= 'bg-red-50 text-red-600 border-red-200' if farm.critical? %> <%= 'bg-yellow-50 text-yellow-700 border-yellow-200' if farm.warning? %> <%= 'bg-green-50 text-green-700 border-green-200' if farm.normal? %>">
          <%= farm.status.capitalize %>
        </span>
      </div>

      <div class="px-4 py-3">
        <% active_alerts = farm.alerts.select(&:active?) %>
        <% if active_alerts.any? %>
          <% critical_count = active_alerts.count { |a| a.critical? } %>
          <% warning_count = active_alerts.count { |a| a.warning? } %>
          <div class="text-sm font-semibold mb-2 flex items-center gap-1.5 <%= 'text-red-600' if critical_count > 0 %> <%= 'text-yellow-700' if critical_count == 0 && warning_count > 0 %>">
            <% if critical_count > 0 %>
              <span class="text-red-600"><%= icon :exclamation_circle, class: "w-4 h-4" %></span>
            <% else %>
              <span class="text-yellow-700"><%= icon :exclamation_triangle, class: "w-4 h-4" %></span>
            <% end %>
            <%= pluralize(critical_count, 'Critical Alert') %><%= ", #{warning_count} Warning" if warning_count > 0 %>
          </div>
          <div class="flex flex-wrap gap-1.5 mb-2">
            <% sorted = active_alerts.sort_by { |a| a.alert_type.match?(/ammonia/i) ? 0 : a.alert_type.match?(/temperature|fan/i) ? 1 : 2 } %>
            <% sorted.first(4).each do |alert| %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full border <%= alert.critical? ? 'bg-red-50 text-red-600 border-red-200' : 'bg-yellow-50 text-yellow-700 border-yellow-200' %>">
                <%= icon :bolt, class: "w-3 h-3" if alert.alert_type.match?(/ammonia/i) %>
                <%= icon :thermometer, class: "w-3 h-3" if alert.alert_type.match?(/temperature/i) %>
                <%= icon :fan, class: "w-3 h-3" if alert.alert_type.match?(/fan/i) %>
                <%= icon :droplet, class: "w-3 h-3" if alert.alert_type.match?(/humidity/i) %>
                <%= alert.alert_type.humanize %><% if alert.zone %> · <%= alert.zone.name %><% end %>
              </span>
            <% end %>
          </div>
        <% else %>
          <div class="text-sm font-semibold mb-2 text-green-600 flex items-center gap-1.5">
            <%= icon :check, class: "w-4 h-4" %> All systems normal
          </div>
        <% end %>

        <div class="flex gap-4 pt-3 mt-1 border-t border-gray-200">
          <% latest = farm.zones.flat_map(&:sensors) %>
          <% ammo = latest.select { |s| s.ammonia? }.map { |s| s.latest_reading }.compact.first %>
          <% temp = latest.select { |s| s.temperature? }.map { |s| s.latest_reading }.compact.first %>
          <% fan_sensors = latest.select(&:fan?) %>
          <% total_fans = fan_sensors.size %>
          <% online_fans = fan_sensors.count(&:online?) %>
          <% humid = latest.select { |s| s.humidity? }.map { |s| s.latest_reading }.compact.first %>
          <% if ammo %>
            <div class="flex items-center gap-1.5">
              <%= icon :bolt, class: "w-3.5 h-3.5 text-gray-500" %>
              <span class="text-xs font-semibold text-gray-500"><%= ammo.value %> ppm</span>
            </div>
          <% end %>
          <% if temp %>
            <div class="flex items-center gap-1.5">
              <%= icon :thermometer, class: "w-3.5 h-3.5 text-gray-500" %>
              <span class="text-xs font-semibold text-gray-500"><%= temp.value %>°C</span>
            </div>
          <% end %>
          <% if fan_sensors.any? %>
            <div class="flex items-center gap-1.5">
              <%= icon :fan, class: "w-3.5 h-3.5 text-gray-500" %>
              <span class="text-xs font-semibold text-gray-500"><%= online_fans %>/<%= total_fans %></span>
            </div>
          <% end %>
          <% if humid %>
            <div class="flex items-center gap-1.5">
              <%= icon :droplet, class: "w-3.5 h-3.5 text-gray-500" %>
              <span class="text-xs font-semibold text-gray-500"><%= humid.value %>%</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
