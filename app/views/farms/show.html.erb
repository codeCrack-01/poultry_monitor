<div class="sticky top-0 z-50 bg-white/96 backdrop-blur-md border-b border-gray-200 px-4 py-2.5 flex items-center justify-between">
  <div class="flex items-center gap-2.5">
    <%= link_to farms_path, class: "w-8 h-8 rounded-md border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50 no-underline" do %>
      <%= icon :chevron_left, class: "w-4 h-4" %>
    <% end %>
    <div>
      <div class="text-sm font-semibold"><%= @farm.name %></div>
      <div class="text-[11px] text-gray-400">Shed 1 · <%= @farm.sheds.flat_map(&:zones).size %> Zones</div>
    </div>
  </div>
  <div>
    <%= link_to alerts_path, class: "relative w-9 h-9 rounded-md border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50" do %>
      <%= icon :bell, class: "w-4 h-4" %>
      <% if @alerts.any? %>
        <span class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-red-500 border-2 border-white"></span>
      <% end %>
    <% end %>
  </div>
</div>

<% status_color = @farm.critical? ? 'red' : (@farm.warning? ? 'yellow' : 'green') %>
<% if @farm.critical? %>
  <% status_text = "#{@alerts.count { |a| a.critical? }} critical issue".pluralize %>
<% elsif @farm.warning? %>
  <% status_text = "#{@alerts.count { |a| a.warning? }} warning".pluralize %>
<% else %>
  <% status_text = "All systems normal" %>
<% end %>
<div class="flex items-center gap-2.5 px-4 py-2.5 bg-white border-b border-gray-200">
  <div class="w-2 h-2 rounded-full bg-<%= status_color %>-500 shadow-[0_0_0_0_rgba(<%= status_color == 'red' ? '199,84,80' : (status_color == 'yellow' ? '164,106,0' : '53,122,74') %>,0.4)] animate-pulse"></div>
  <span class="text-sm font-medium text-<%= status_color %>-500"><%= status_text %></span>
  <span class="ml-auto text-[11px] text-gray-400">Updated just now</span>
</div>

<div class="px-4 pt-3 pb-24">
  <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wide mb-2.5">Shed Zones</div>
  <% @farm.sheds.each do |shed| %>
    <div class="grid grid-cols-2 gap-2 mb-3.5">
      <% shed.zones.each do |zone| %>
        <%= link_to zone_path(zone), class: "block bg-gray-50 border-2 rounded-lg p-3 text-center hover:border-gray-300 active:scale-95 transition-all no-underline #{'border-green-200 bg-green-50' if zone.normal?} #{'border-yellow-200 bg-yellow-50' if zone.warning?} #{'border-red-500 bg-red-50 animate-pulse' if zone.critical?}" do %>
          <div class="text-base font-semibold text-gray-900">Zone <%= zone.name %></div>
          <div class="text-[11px] mt-1.5 px-2 py-0.5 inline-block rounded-full border font-semibold <%= 'bg-green-50 text-green-700 border-green-200' if zone.normal? %> <%= 'bg-yellow-50 text-yellow-700 border-yellow-200' if zone.warning? %> <%= 'bg-red-50 text-red-600 border-red-200' if zone.critical? %>">
            <%= zone.status.capitalize %>
          </div>
          <div class="mt-2 space-y-1">
            <% zone.sensors.select(&:ammonia?).each do |s| %>
              <% r = s.latest_reading %>
              <% next unless r %>
              <div class="flex items-center justify-center gap-1 text-[11px] <%= r.value > 20 ? 'text-red-600 font-semibold' : 'text-gray-500' %>">
                <%= icon :bolt, class: "w-3 h-3" %> <%= r.value %> ppm
              </div>
            <% end %>
            <% zone.sensors.select(&:temperature?).each do |s| %>
              <% r = s.latest_reading %>
              <% next unless r %>
              <div class="flex items-center justify-center gap-1 text-[11px] <%= r.value > 26 ? 'text-red-600 font-semibold' : 'text-gray-500' %>">
                <%= icon :thermometer, class: "w-3 h-3" %> <%= r.value %>°C
              </div>
            <% end %>
            <% zone.sensors.select(&:fan?).select(&:offline?).each do |f| %>
              <div class="flex items-center justify-center gap-1 text-[11px] text-red-600 font-semibold">
                <%= icon :x_mark, class: "w-3 h-3" %> <%= f.label %>
              </div>
            <% end %>
            <% zone.sensors.select(&:humidity?).each do |s| %>
              <% r = s.latest_reading %>
              <% next unless r %>
              <div class="flex items-center justify-center gap-1 text-[11px] text-gray-500">
                <%= icon :droplet, class: "w-3 h-3" %> <%= r.value %>%
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% gen = @farm.sheds.flat_map { |s| s.zones.flat_map(&:sensors) }.detect(&:generator?) %>
  <% if gen %>
    <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wide mb-2.5">Equipment</div>
    <div class="bg-white border border-gray-200 rounded-lg p-3.5 shadow-sm">
      <div class="flex items-center justify-between mb-2.5">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded text-xs flex items-center justify-center border bg-orange-50 text-orange-600 border-orange-200">
            <%= icon :cog, class: "w-3.5 h-3.5" %>
          </div>
          <span class="text-sm font-semibold">Generator</span>
        </div>
        <span class="text-[11px] font-semibold uppercase px-2 py-0.5 rounded-full border bg-green-50 text-green-700 border-green-200">
          <%= gen.online? ? 'Running' : 'Offline' %>
        </span>
      </div>
      <% gen_reading = gen.latest_reading %>
      <div class="text-xs text-gray-500">Backup Power · Fuel: <%= gen_reading&.value || 'N/A' %>%</div>
    </div>
  <% end %>
</div>
