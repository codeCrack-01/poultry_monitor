<div class="fixed bottom-0 left-0 right-0 md:max-w-[430px] md:mx-auto bg-white/96 backdrop-blur-md border-t border-gray-200 flex justify-around px-2 py-1 pb-4 z-100">
  <%= link_to farms_path, class: "flex flex-col items-center gap-0.5 px-4 py-1.5 #{'text-blue-600' if current_page?(farms_path) || controller_name == 'farms' && action_name == 'index'} #{controller_name == 'alerts' ? 'text-gray-400' : ''} transition-colors" do %>
    <%= icon :home, class: "w-5 h-5" %>
    <span class="text-[10px] font-medium">Farms</span>
  <% end %>

  <%= link_to alerts_path, class: "flex flex-col items-center gap-0.5 px-4 py-1.5 #{'text-blue-600' if current_page?(alerts_path)} text-gray-400 transition-colors" do %>
    <%= icon :bell, class: "w-5 h-5" %>
    <span class="text-[10px] font-medium">Alerts</span>
  <% end %>

  <div class="flex flex-col items-center gap-0.5 px-4 py-1.5 text-gray-400 cursor-default">
    <%= icon :cog, class: "w-5 h-5" %>
    <span class="text-[10px] font-medium">Settings</span>
  </div>
</div>
